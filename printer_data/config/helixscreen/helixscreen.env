# SPDX-License-Identifier: GPL-3.0-or-later
#
# Environment configuration for HelixScreen
#
# This file can be sourced by the launcher script or referenced by systemd.
# Copy to /etc/helixscreen/helixscreen.env and customize as needed.
#
# Usage with systemd:
#   Add to [Service] section: EnvironmentFile=/etc/helixscreen/helixscreen.env

# Display backend (auto-detected if not set)
# Resolution is auto-detected from display hardware
# Options: sdl, fbdev, drm
#HELIX_DISPLAY_BACKEND=fbdev

# Framebuffer device (for fbdev backend)
#HELIX_FB_DEVICE=/dev/fb0

# DRM device (for drm backend)
#HELIX_DRM_DEVICE=/dev/dri/card0

# Moonraker connection
MOONRAKER_HOST=localhost
MOONRAKER_PORT=7125

# Logging level (trace, debug, info, warn, error, critical, off)
# Normally controlled in-app via Settings → System → Log Level (persists to
# settings.json). Uncommenting here passes --log-level=<value> to helix-screen
# and **overrides the in-app setting**, so leave it commented unless you need
# a level applied before settings.json is loaded (e.g. debugging an early
# startup crash, or capturing journalctl output before the UI is reachable).
#HELIX_LOG_LEVEL=info

# Log destination (auto, journal, syslog, file, console)
# Default: auto — uses systemd journal if available, then syslog, then console.
# Most users should leave this as "auto".
#HELIX_LOG_DEST=auto

# Log file path — ONLY used as a FALLBACK when no system-level logging service
# (systemd journal or syslog) is available or active. With the default log
# destination of "auto", this path is ignored on systems that have journald or
# syslog running. You only need this on minimal/embedded systems with no
# logging daemon, or if you explicitly set HELIX_LOG_DEST=file.
#HELIX_LOG_FILE=/tmp/helixscreen.log

# Screen size override (alternative to -s command line flag)
# Accepts named presets: micro (480x272), tiny (480x320), small (480x400),
#   medium (800x480), large (1024x600), xlarge (1280x720)
# Or custom WxH format: 480x400, 1920x1080, etc.
# Auto-detected from display hardware if not set.
# The -s command line flag takes priority over this variable.
#HELIX_SCREEN_SIZE=medium

# Display DPI override (50-500, auto-detected if not set)
# Useful for screens where spacing looks wrong at default DPI
#HELIX_DPI=240

# Skip splash screen (for debugging)
#HELIX_SKIP_SPLASH=1

# Auto-quit after N milliseconds (for testing)
#HELIX_AUTO_QUIT_MS=10000

# Enable screenshots (press 'S' key or automatic)
#HELIX_AUTO_SCREENSHOT=1

# Allow running without a touchscreen (headless/VNC setups)
#HELIX_REQUIRE_POINTER=0

# Force touch calibration on next launch. Useful when the screen is too
# miscalibrated to navigate to Settings → Touch Calibration. Set to any
# value to enable, then remove the line after calibration succeeds — the
# variable does not self-clear and would re-trigger calibration on every
# restart. Works from both states: if the first-run wizard is pending,
# it pins step 0 (touch calibration) and bypasses the auto-skip;
# otherwise it opens the standalone calibration overlay after startup.
# Same effect as the --calibrate-touch CLI flag and the
# /input/force_calibration config option.
#HELIX_TOUCH_CALIBRATE=1

# Force red/blue channel swap for BGR framebuffers.
# HelixScreen auto-detects BGR layout from kernel fb_var_screeninfo, but some
# display drivers report incorrect pixel format (says RGB but panel is BGR).
# Symptoms: red appears blue and blue appears red, green is unaffected.
# Set to 1 to force swap ON, 0 to force swap OFF (overrides auto-detection).
# Only applies to fbdev backend.
#HELIX_COLOR_SWAP_RB=1

# Enhanced 2D G-code shading (enabled by default)
# Adds per-segment directional lighting, anti-aliased lines, and silhouette
# outline to the 2D G-code preview for improved depth perception.
# Set to 0 to disable and use the original flat shading.
#HELIX_SSAO=0

# Heap-corruption diagnostics (auto-enabled on AD5M/AD5X by helix-launcher.sh)
# MALLOC_CHECK_=3 makes glibc abort on malloc metadata corruption and print a
# diagnostic ("free(): invalid pointer", "double free detected", etc.) to
# stderr/syslog before the SIGABRT, so otherwise-unactionable crash bundles
# name the corruption class. MALLOC_PERTURB_=165 poisons freed memory to
# surface use-after-free at the actual read. ~5–15% malloc overhead.
# Set MALLOC_CHECK_=0 below to disable on AD5M/AD5X if needed.
#MALLOC_CHECK_=3
#MALLOC_PERTURB_=165
